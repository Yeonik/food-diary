# These defaults are for LOCAL development. In production (see the "Deploying"
# section of the README) the platform's environment must set APP_ENV=production,
# APP_DEBUG=false and APP_URL=https://... — a debug error page renders the Gemini
# and USDA keys, so APP_DEBUG must never be true on an internet-facing instance.
# The listening port comes from $PORT there and must NOT be pinned here.
APP_NAME="Food diary"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# In production over HTTPS, set this true so the session cookie is Secure-only.
# Leave it unset for local http, or the session cookie is never sent.
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Food diary ---------------------------------------------------------------

# Host port to publish the app on (change it if 8000 is taken).
APP_PORT=8000

# The owner's account, created once when migrations first run. Without
# OWNER_EMAIL the migration refuses BEFORE it writes anything, so a deploy that
# forgot it fails and leaves the database untouched rather than producing an
# instance nobody can sign in to. Remove OWNER_PASSWORD after the first sign-in:
# re-running migrations never rewrites an account that already exists, so a
# password changed in the app is not reset by a variable left behind.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-this-before-you-deploy
# OWNER_NAME=


# Google Gemini — the only outbound recognition call, and the only recogniser
# the running app uses. Without a key, photo recognition fails loudly and never
# invents a result; manual entry, library, weight and goals still work. There is
# no "fake" mode — the fake recogniser exists only inside the test suite.
GEMINI_API_KEY=
# A model your key can actually call. Google gives some models a free-tier quota
# of 0 (they answer 429) and hides others from new keys (404); pick one your key
# reaches. gemini-3.5-flash works on the free tier and is a stable pinned name.
GEMINI_MODEL=gemini-3.5-flash
# Per-attempt timeout (seconds) for the recognition call. Recognition retries a
# couple of times on a busy model, so keep this generous rather than snappy.
GEMINI_TIMEOUT=60

# Recognitions one account may ask for per day. There is one key on the
# installation and every account spends from it. Counted when a recognition is
# asked for, not when it succeeds — a failed call costs the key the same.
# 0 means nobody recognises anything; it is an off switch, not "unlimited".
RECOGNITION_DAILY_LIMIT=25

# USDA FoodData Central — free key from https://api.data.gov (sent as a header).
USDA_API_KEY=

# Open Food Facts needs no key; a descriptive User-Agent is requested by its terms.
OFF_USER_AGENT="food-diary/1.0 (self-hosted)"

# Photos: max edge in pixels, and whether to delete the file once confirmed.
PHOTO_MAX_DIMENSION=1600
PHOTO_DELETE_AFTER_CONFIRM=true
