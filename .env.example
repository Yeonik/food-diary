APP_NAME="Food diary"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Food diary ---------------------------------------------------------------

# Optional single access password for this self-hosted instance. Leave blank and
# the diary is open; set it and every page requires unlocking once per session.
APP_ACCESS_PASSWORD=

# Google Gemini — the only outbound recognition call, and the only recogniser
# the running app uses. Without a key, photo recognition fails loudly and never
# invents a result; manual entry, library, weight and goals still work. There is
# no "fake" mode — the fake recogniser exists only inside the test suite.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# USDA FoodData Central — free key from https://api.data.gov (sent as a header).
USDA_API_KEY=

# Open Food Facts needs no key; a descriptive User-Agent is requested by its terms.
OFF_USER_AGENT="food-diary/1.0 (self-hosted)"

# Photos: max edge in pixels, and whether to delete the file once confirmed.
PHOTO_MAX_DIMENSION=1600
PHOTO_DELETE_AFTER_CONFIRM=true
